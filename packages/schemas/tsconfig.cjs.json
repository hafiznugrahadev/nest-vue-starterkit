{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // CommonJS build — consumed by the NestJS runtime, Jest, and plain Node.
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist/cjs",
    "rootDir": "./src",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src/**/*"]
}
