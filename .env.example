# ╭──────────────────────────────────────────────────────────────────────────╮
# │ starterkit — SINGLE root .env for the whole monorepo                         │
# │                                                                            │
# │   Quick start:  cp .env.example .env  &&  docker compose up                  │
# │   Everything below already has a working DEV default — you shouldn't need    │
# │   to change anything to boot the stack. Tweak only what you want.            │
# │                                                                            │
# │   Who reads this file:                                                        │
# │     • docker-compose      → variable substitution (infra + apps)             │
# │     • apps/api  (NestJS)   → ConfigModule envFilePath: ../../.env             │
# │     • apps/web       → Vite loads VITE_* at dev/build time             │
# ╰──────────────────────────────────────────────────────────────────────────╯
#
# Dev runs on the `localdev` docker network (auto-created by compose). OrbStack
# issues HTTPS for these *.starterkit.local domains automatically:
#     https://app.starterkit.local      → web (frontend)
#     https://api.starterkit.local      → api (backend)
#     https://adminer.starterkit.local  → Adminer (PostgreSQL UI)
#     https://mailpit.starterkit.local  → Mailpit (sent emails)
#     https://rustfs.starterkit.local   → RustFS console (S3 storage)
#     postgres.starterkit.local:5432    → PostgreSQL (for DB clients)
#     redis.starterkit.local:6379       → Redis (for clients)
#
# The compose stack publishes NO host ports — every service is reached through the
# domains above (nginx + OrbStack proxy), never localhost:<port>.

# ── App ports (in-container listen ports — NOT forwarded to the host) ─────────
# These only set what api/web listen on internally (and on the host when running
# `bun run serve` without Docker). The Docker stack does not map them to the host.
WEB_PORT=4301
API_PORT=4400

# ── Domains & URLs (dev defaults work out of the box with OrbStack) ──────────
# Frontend base URL — single source of truth (drives CORS + password-reset link).
APP_URL=https://app.starterkit.local
# Allowed CORS origin(s) for credentialed requests. Defaults to APP_URL.
CORS_ORIGIN=https://app.starterkit.local
# Shared parent domain so the httpOnly refresh cookie reaches BOTH subdomains.
# Leave blank for plain localhost (single-origin) dev.
COOKIE_DOMAIN=starterkit.local

# ── Frontend (web / Vite) — public, exposed to the browser ─────────────
# Browser → API base. Baked into the client bundle at build time.
VITE_API_BASE=https://api.starterkit.local/api
# Server-only: SSR → API call goes over the internal docker network (no TLS).
API_INTERNAL_BASE=http://api:8080/api
# Vite HMR dials this host over wss (behind the nginx + OrbStack proxy).
VITE_HMR_HOST=app.starterkit.local

# ── Registration (self-service sign-up) ──────────────────────────────────────
# One switch drives both the API and the frontend in the compose stack.
REGISTRATION_ENABLED=true

# ── API runtime ──────────────────────────────────────────────────────────────
NODE_ENV=development
API_PREFIX=api
LOG_LEVEL=debug

# ── File logging (daily rotation, retained N days; viewer at /logs for super admins)
# Logs are written to LOG_DIR as daily-rotated JSON files (app.<date>.<n>.log) and
# mounted to a disk volume in prod/dokploy. Set LOG_FILE_ENABLED=false for stdout-only.
LOG_DIR=./storage/logs
LOG_RETENTION_DAYS=7
LOG_FILE_ENABLED=true

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=starterkit
POSTGRES_PASSWORD=starterkit
POSTGRES_DB=starterkit
# Used by Drizzle Kit from the HOST (db:migrate / db:seed / db:studio). No host port
# is published, so reach Postgres via its OrbStack domain. Inside docker the api
# container talks to the `postgres` service directly.
DATABASE_URL=postgresql://starterkit:starterkit@postgres.starterkit.local:5432/starterkit?schema=public

# ── Redis ─────────────────────────────────────────────────────────────────────
# Host access (API running outside Docker) goes via the OrbStack domain; inside
# docker the api uses the `redis` service name.
REDIS_HOST=redis.starterkit.local
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-me-min-16-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# ── Swagger docs (Basic Auth protected) ──────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_USER=admin
SWAGGER_PASSWORD=admin

# ── Rate limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
# Dev/E2E: skip ALL rate limiting so rapid test runs aren't throttled.
THROTTLE_DISABLED=true

# ── File storage (uploads) ────────────────────────────────────────────────────
# "local" = zero-infra (writes to apps/api/storage/uploads, served at /uploads).
# "s3"    = AWS S3 / MinIO / RustFS (RustFS runs in the dev compose stack).
STORAGE_DRIVER=local
STORAGE_MAX_FILE_SIZE_MB=5
# RustFS credentials (s3 driver only). No host port is published; api uses http://rustfs:9000 in-docker, console at https://rustfs.starterkit.local.
S3_ENDPOINT=http://rustfs:9000
S3_REGION=us-east-1
S3_BUCKET=starterkit
S3_ACCESS_KEY_ID=rustfsadmin
S3_SECRET_ACCESS_KEY=rustfsadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/starterkit

# ── Mail ──────────────────────────────────────────────────────────────────────
# Dev compose routes mail to Mailpit (UI at https://mailpit.starterkit.local). These values
# apply when running the API directly on the host (non-docker): "log" just prints
# emails to the API logs.
MAIL_TRANSPORT=log
MAIL_FROM=Starter Kit <no-reply@starterkit.test>
MAIL_SMTP_HOST=localhost
MAIL_SMTP_PORT=1025
MAIL_SMTP_SECURE=false
MAIL_SMTP_USER=
MAIL_SMTP_PASSWORD=

# ── Password reset ────────────────────────────────────────────────────────────
PASSWORD_RESET_TTL_MIN=30
# Reset link = APP_URL + /reset-password (no separate variable needed).

# ╭──────────────────────────────────────────────────────────────────────────╮
# │ PROD — you'll swap these yourself (docker-compose.prod.yml is self-hosted;   │
# │ docker-compose.dokploy.yml provisions infra in the Dokploy UI). Reminders:   │
# │   • Strong POSTGRES_PASSWORD / REDIS_PASSWORD / JWT_SECRET                    │
# │   • NODE_ENV=production  → cookies become Secure + SameSite=None              │
# │   • APP_URL / VITE_API_BASE → your real https domains                        │
# │   • MAIL_TRANSPORT=smtp → a real provider (SendGrid / Resend / SES)          │
# │   • REGISTRATION_ENABLED=false unless you want open sign-up                   │
# ╰──────────────────────────────────────────────────────────────────────────╯
